            "rgba(156, 163, 175, 0.6)",
            "rgba(156, 163, 175, 0.6)",
            "rgba(156, 163, 175, 0.6)",
            "rgba(251, 146, 60, 0.8)",
            "rgba(220, 38, 38, 0.9)"
          ],
          "borderColor": [
            "rgba(156, 163, 175, 0.8)",
